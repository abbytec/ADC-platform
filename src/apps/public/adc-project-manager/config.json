{
	"uiModule": {
		"name": "adc-project-manager",
		"uiNamespace": "adc-platform",
		"framework": "react",
		"outputDir": "dist-ui",
		"isHost": true,
		"isRemote": false,
		"serviceWorker": true,
		"uiDependencies": ["adc-ui-library"],
		"devPort": 3018,
		"sharedLibs": ["react", "tailwind"],
		"i18n": true,
		"hosting": [
			{
				"domains": ["adigitalcafe.com"],
				"subdomains": ["projects"]
			}
		],
		"federationExposes": {
			"./App": "./src/App.tsx"
		}
	},
	"services": [
		{
			"name": "data/ProjectManagerService",
			"version": "latest"
		},
		{
			"name": "IdentityManagerService",
			"version": "latest"
		}
	]
}

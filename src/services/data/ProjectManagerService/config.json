{
	"name": "ProjectManagerService",
	"version": "1.0.0",
	"failOnError": false,
	"providers": [
		{
			"name": "object/mongo",
			"version": "latest",
			"language": "typescript",
			"custom": {
				"uri": "mongodb://admin:password@localhost:27017/project-management?authSource=admin",
				"maxRetries": 5,
				"retryDelay": 5000
			}
		}
	],
	"services": [
		{
			"name": "IdentityManagerService",
			"version": "latest"
		},
		{
			"name": "EndpointManagerService",
			"version": "latest"
		},
		{
			"name": "OperationsService",
			"version": "latest"
		}
	]
}

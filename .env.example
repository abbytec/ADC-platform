# Plataforma / providers globales
LOG_LEVEL=DEBUG
HTTP_BODY_LIMIT_BYTES=1048576
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010,http://localhost:3012,http://localhost:3014,http://localhost:3016,http://localhost:3018
SECURITY_CSP_ENFORCE=false
SECURITY_ENABLE_HSTS=false
ENDPOINT_RATE_LIMIT_READ_MAX=600
ENDPOINT_RATE_LIMIT_MUTATION_MAX=120
ENDPOINT_RATE_LIMIT_WINDOW_MS=60000

# Producción: mover orígenes a HTTPS exactos y habilitar HSTS.
# SECURITY_ENABLE_HSTS=true
